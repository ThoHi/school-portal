# OS files
.DS_Store
Thumbs.db
desktop.ini

# Editor/IDE
.vscode/
.idea/
*.swp

# Logs
*.log

# Dependencies (if added later)
node_modules/

# Build output
dist/
build/

# Kiwix ZIM files (large, downloaded separately)
wikipedia/zim/*.zim

# calibre-web library + config (books are large; config is per-server state).
# The empty seed metadata.db is kept so first-run works on a fresh clone.
calibre/books/*
!calibre/books/metadata.db
calibre/config/

# Secrets — never commit. Copy .env.example to .env and fill in real values.
.env
