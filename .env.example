# Scholastica secrets — copy this file to `.env` and fill in real values.
# `.env` is git-ignored. docker-compose reads it automatically.
# Generate strong values, e.g.:  python -c "import secrets;print(secrets.token_urlsafe(32))"

# Student API: signs the session tokens. If weak/known, tokens can be forged.
API_SECRET_KEY=change-me-to-a-long-random-string

# Shared secret between the exam app (SERVICE_TOKEN) and the student API
# (EXAM_SERVICE_TOKEN) for the per-student results link. Both must match.
EXAM_SERVICE_TOKEN=change-me-to-a-random-string

# AI Notebook: teacher upload/admin token.
NOTEBOOK_ADMIN_TOKEN=change-me-to-a-random-string

# AI proxy access token. Leave EMPTY for open access on a trusted LAN (the
# browser Research chat needs no token). SET it when you configure a cloud key
# or expose the proxy — then only server-side callers (ai-notebook) and clients
# that send the token may use it. Browser clients would expose it, so don't put
# a cloud-backed, token-protected proxy on the public network.
PROXY_TOKEN=

# Cloud LLM fallback for the ai-proxy (optional; leave blank to disable).
# Any OpenAI-compatible API: OpenAI https://api.openai.com/v1 · OpenRouter https://openrouter.ai/api/v1
CLOUD_API_URL=
CLOUD_API_KEY=
CLOUD_MODEL=
